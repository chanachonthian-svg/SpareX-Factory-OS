{
  "name": "sparex-factoryos-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "mqtt": "tsx src/mqtt/ingest.ts",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/copilot.integration.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mqtt": "^5.10.3",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
