# SPAREX FACTORYOS™ — environment

# Optional: enables the live AI Copilot (Gemini). Without it the Copilot
# falls back to high-quality scripted answers, so the app runs zero-config.
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional legacy fallback: enables Anthropic Claude if Gemini is not configured
# or returns an error.
ANTHROPIC_API_KEY=

# Model used by Claude fallback when ANTHROPIC_API_KEY is present.
COPILOT_MODEL=claude-opus-4-8
